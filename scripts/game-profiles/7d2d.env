WORLD_BUCKET=7d2d-state-prod
S3_PREFIX=servers
GAMECONFIG_S3_KEY=servers/7d2d/config/serverconfig.xml
GAME_NAME=7d2d
AMI_ID=ami-0d7405d05f836d0d4
SUBNET_ID=subnet-0a5490a61e91eda0f
SECURITY_GROUP_IDS="sg-0caca827ece0684c1"
GAME_UDP_PORTS="26900,26901,26902,26903"
GAME_TCP_PORTS="26900,8081"
GAME_INGRESS_CIDR="0.0.0.0/0"
ENSURE_PROFILE_SECURITY_GROUP_RULES=1
KEY_NAME=jajoga
IAM_INSTANCE_PROFILE=7d2d-ec2-role
DEFAULT_INSTANCE_TYPE=c7i.xlarge
BACKUP_INTERVAL_MINUTES=5
RECOMMENDED_INSTANCE_TYPES='c7i.large # very budget (2vCPU/4GiB)
c7i.xlarge # recommended baseline (4vCPU/8GiB)
c7i.2xlarge # safer for mods/player spikes (8vCPU/16GiB)'

# 7 Days to Die server specifics
STATE_DIR_PATH=/srv/7d2d-state
STATE_LINK=
GAME_HOME=/opt/7d2d
STEAM_BETA_BRANCH="latest_experimental"
STEAM_BETA_PASSWORD=""
GAME_INSTALL_CMD='/opt/steamcmd/steamcmd.sh +@sSteamCmdForcePlatformType linux +force_install_dir /opt/7d2d +login anonymous +app_update 294420 ${STEAM_BETA_BRANCH:+-beta ${STEAM_BETA_BRANCH}} ${STEAM_BETA_PASSWORD:+-betapassword ${STEAM_BETA_PASSWORD}} validate +quit'
GAME_START_CMD="cd /opt/7d2d && ./7DaysToDieServer.x86_64 -logfile /var/log/7d2d/server.log -configfile=serverconfig.xml -batchmode -nographics -dedicated"
