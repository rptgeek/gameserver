WORLD_BUCKET=gameserver-state-example
S3_PREFIX=servers
GAME_NAME=windrose
AWS_REGION=us-east-1
# Use either an explicit AMI ID or an SSM AMI parameter.
AMI_ID=ami-xxxxxxxxxxxxxxxxx
SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
SECURITY_GROUP_IDS="sg-xxxxxxxxxxxxxxxxx"

# Windrose dedicated server direct-connection ports.
GAME_UDP_PORTS="7777"
GAME_TCP_PORTS="7777"
GAME_INGRESS_CIDR="0.0.0.0/0"
ENSURE_PROFILE_SECURITY_GROUP_RULES=1

KEY_NAME=example-key
IAM_INSTANCE_PROFILE=example-game-server-role
DEFAULT_INSTANCE_TYPE=c7i.xlarge
VOLUME_SIZE_GIB=80
BACKUP_INTERVAL_MINUTES=5
RECOMMENDED_INSTANCE_TYPES='c7i.large # very budget (2vCPU/4GiB)
c7i.xlarge # baseline (4vCPU/8GiB)
c7i.2xlarge # safer for higher player load (8vCPU/16GiB)'

# WindRose server specifics
STEAM_BETA_BRANCH=""
STEAM_BETA_PASSWORD=""
STATE_DIR_PATH=/srv/windrose-state
STATE_LINK=__none__
GAME_HOME=/opt/windrose
SERVICE_USER=root
GAME_INSTALL_CMD='apt-get update && apt-get install -y docker.io && systemctl enable --now docker && docker pull windroseserver/windroseserver:latest'
GAME_START_CMD='mkdir -p /srv/windrose-state/Saved && if docker container inspect WindroseServer >/dev/null 2>&1; then docker rm -f WindroseServer >/dev/null 2>&1 || true; fi && docker_args=(-p 7777:7777/tcp -p 7777:7777/udp -v /srv/windrose-state/Saved:/home/ue_user/app/R5/Saved); if [[ -f /srv/windrose-state/ServerDescription.json ]]; then docker_args+=(-v /srv/windrose-state/ServerDescription.json:/home/ue_user/app/R5/ServerDescription.json); fi && exec docker run --name WindroseServer "${docker_args[@]}" windroseserver/windroseserver:latest'
