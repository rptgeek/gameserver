#!/usr/bin/env bash
set -euo pipefail

export AWS_DEFAULT_REGION={{WORLD_BUCKET_REGION}}

WORLD_BUCKET={{WORLD_BUCKET}}
GAME_STATE_PREFIX={{GAME_STATE_PREFIX}}
WORLD_PREFIX={{WORLD_PREFIX}}
STATE_DIR_PATH={{STATE_DIR_PATH}}
STATE_LINK={{STATE_LINK}}
GAME_NAME={{GAME_NAME}}
SERVICE_USER={{SERVICE_USER}}
GAME_SERVICE={{GAME_SERVICE}}
GAME_HOME={{GAME_HOME}}
GAMECONFIG_S3_KEY={{GAMECONFIG_S3_KEY}}
GAMECONFIG_LOCAL_PATH={{GAMECONFIG_LOCAL_PATH}}
BACKUP_INTERVAL_MINUTES={{BACKUP_INTERVAL_MINUTES}}
BACKUP_BOOT_OFFSET_MINUTES={{BACKUP_BOOT_OFFSET_MINUTES}}
STOP_TIMEOUT_SECONDS={{STOP_TIMEOUT_SECONDS}}
GAME_INSTALL_CMD_B64={{GAME_INSTALL_CMD_B64}}
GAME_START_CMD_B64={{GAME_START_CMD_B64}}
STEAM_BETA_BRANCH={{STEAM_BETA_BRANCH}}
STEAM_BETA_PASSWORD={{STEAM_BETA_PASSWORD}}
GAME_UDP_PORTS={{GAME_UDP_PORTS}}
GAME_TCP_PORTS={{GAME_TCP_PORTS}}
GAME_INGRESS_CIDR={{GAME_INGRESS_CIDR}}
ENFORCE_BOOTSTRAP_LOG_PREFIX={{ENFORCE_BOOTSTRAP_LOG_PREFIX}}
ENFORCE_SERVER_LOG_PREFIX={{ENFORCE_SERVER_LOG_PREFIX}}
EC2_INSTANCE_ID="${EC2_INSTANCE_ID:-$(curl -fsS http://169.254.169.254/latest/meta-data/instance-id || true)}"

strip_wrapping_quotes() {
  local value="${1:-}"
  value="${value#\"}"
  value="${value%\"}"
  value="${value#\'}"
  value="${value%\'}"
  printf '%s' "${value}"
}

AWS_DEFAULT_REGION="$(strip_wrapping_quotes "${AWS_DEFAULT_REGION}")"
WORLD_BUCKET="$(strip_wrapping_quotes "${WORLD_BUCKET}")"
GAME_STATE_PREFIX="$(strip_wrapping_quotes "${GAME_STATE_PREFIX}")"
WORLD_PREFIX="$(strip_wrapping_quotes "${WORLD_PREFIX}")"
STATE_DIR_PATH="$(strip_wrapping_quotes "${STATE_DIR_PATH}")"
STATE_LINK="$(strip_wrapping_quotes "${STATE_LINK}")"
GAME_NAME="$(strip_wrapping_quotes "${GAME_NAME}")"
SERVICE_USER="$(strip_wrapping_quotes "${SERVICE_USER}")"
GAME_SERVICE="$(strip_wrapping_quotes "${GAME_SERVICE}")"
GAME_HOME="$(strip_wrapping_quotes "${GAME_HOME}")"
GAMECONFIG_S3_KEY="$(strip_wrapping_quotes "${GAMECONFIG_S3_KEY}")"
GAMECONFIG_LOCAL_PATH="$(strip_wrapping_quotes "${GAMECONFIG_LOCAL_PATH}")"
GAME_INSTALL_CMD_B64="$(strip_wrapping_quotes "${GAME_INSTALL_CMD_B64}")"
GAME_START_CMD_B64="$(strip_wrapping_quotes "${GAME_START_CMD_B64}")"
STEAM_BETA_BRANCH="$(strip_wrapping_quotes "${STEAM_BETA_BRANCH}")"
STEAM_BETA_PASSWORD="$(strip_wrapping_quotes "${STEAM_BETA_PASSWORD}")"
GAME_INGRESS_CIDR="$(strip_wrapping_quotes "${GAME_INGRESS_CIDR}")"
ENFORCE_BOOTSTRAP_LOG_PREFIX="$(strip_wrapping_quotes "${ENFORCE_BOOTSTRAP_LOG_PREFIX}")"
ENFORCE_SERVER_LOG_PREFIX="$(strip_wrapping_quotes "${ENFORCE_SERVER_LOG_PREFIX}")"

decode() {
  printf '%s' "${1}" | base64 -d
}

mkdir -p "/var/log/${GAME_NAME}" "/tmp"
mkdir -p "/opt/${GAME_SERVICE}-tools" "${STATE_DIR_PATH}"
mkdir -p "/etc/systemd/system" "/etc/awslogs" "/var/lib/awslogs"
touch "/var/log/${GAME_NAME}/bootstrap.log" "/var/log/${GAME_NAME}/server.log"
if [[ -n "${EC2_INSTANCE_ID}" ]]; then
  LOG_STREAM_PREFIX="${EC2_INSTANCE_ID}"
else
  LOG_STREAM_PREFIX="$(hostname)-manual"
fi
exec >>"/var/log/${GAME_NAME}/bootstrap.log" 2>&1

if command -v yum >/dev/null 2>&1; then
  yum -y update
  yum -y install ca-certificates tar gzip curl cronie || true
  yum -y install awscli || true
elif command -v apt-get >/dev/null 2>&1; then
  export DEBIAN_FRONTEND=noninteractive
  apt-get update
  apt-get install -y ca-certificates tar gzip curl cron
  apt-get install -y awscli || true
fi

if [[ "${SERVICE_USER}" == "auto" ]]; then
  if id -u ec2-user >/dev/null 2>&1; then
    SERVICE_USER="ec2-user"
  elif id -u ubuntu >/dev/null 2>&1; then
    SERVICE_USER="ubuntu"
  else
    SERVICE_USER="root"
  fi
fi

if ! id -u "${SERVICE_USER}" >/dev/null 2>&1; then
  SERVICE_USER="root"
fi

if [[ -z "${STATE_LINK}" ]]; then
  SERVICE_USER_HOME="$(getent passwd "${SERVICE_USER}" | cut -d: -f6 || true)"
  if [[ -z "${SERVICE_USER_HOME}" ]]; then
    SERVICE_USER_HOME="/home/${SERVICE_USER}"
  fi
  STATE_LINK="${SERVICE_USER_HOME}/.local/share/7DaysToDie"
else
  STATE_LINK="${STATE_LINK%/}"
fi

mkdir -p "${STATE_LINK%/*}"
mkdir -p "${STATE_LINK%/*}/.local/share"
mkdir -p "${GAME_HOME}"
mkdir -p "/var/log/${GAME_NAME}"
touch "/var/log/${GAME_NAME}/bootstrap.log" \
  "/var/log/${GAME_NAME}/server.log" \
  "/var/log/${GAME_NAME}/server.error.log"
mkdir -p "/etc/systemd/system"
ln -sfn "${STATE_DIR_PATH}" "${STATE_LINK}"
mkdir -p "/opt/${GAME_SERVICE}-tools"

if id -u "${SERVICE_USER}" >/dev/null 2>&1; then
  chown -R "${SERVICE_USER}:${SERVICE_USER}" \
    "${STATE_DIR_PATH}" \
    "${STATE_LINK%/*}" \
    "${GAME_HOME}" \
    "/var/log/${GAME_NAME}" || true
  chmod -R u+rwX "${STATE_DIR_PATH}" || true
  chmod -R u+rwX "/var/log/${GAME_NAME}" || true
fi

restore_state() {
  aws s3 sync "s3://${WORLD_BUCKET}/${WORLD_PREFIX}/state/" "${STATE_DIR_PATH}/" || true
  if [[ -d "${STATE_DIR_PATH}" ]] && [[ -n "${SERVICE_USER}" ]] && id -u "${SERVICE_USER}" >/dev/null 2>&1; then
    chown -R "${SERVICE_USER}:${SERVICE_USER}" "${STATE_DIR_PATH}" || true
    chmod -R u+rwX "${STATE_DIR_PATH}" || true
  fi
}

configure_cloudwatch_agent() {
  local bootstrap_group="${ENFORCE_BOOTSTRAP_LOG_PREFIX}"
  local server_group="${ENFORCE_SERVER_LOG_PREFIX}"
  local stream="${LOG_STREAM_PREFIX}"

  if [[ -z "${bootstrap_group}" || -z "${server_group}" ]]; then
    return 0
  fi

  if ! command -v /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl >/dev/null 2>&1; then
    if command -v yum >/dev/null 2>&1; then
      yum -y install amazon-cloudwatch-agent || true
    elif command -v apt-get >/dev/null 2>&1; then
      curl -fsSL https://s3.amazonaws.com/amazoncloudwatch-agent/ubuntu/amd64/latest/amazon-cloudwatch-agent.deb -o /tmp/amazon-cloudwatch-agent.deb || true
      dpkg -i /tmp/amazon-cloudwatch-agent.deb || apt-get install -f -y || true
    fi
  fi

  if ! command -v /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl >/dev/null 2>&1; then
    echo "CloudWatch Agent is unavailable; skipping log shipping setup."
    return 0
  fi

  mkdir -p /opt/aws/amazon-cloudwatch-agent/etc
  cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json <<EOF
{
  "agent": {
    "region": "${AWS_DEFAULT_REGION}"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/${GAME_NAME}/bootstrap.log",
            "log_group_name": "${bootstrap_group}",
            "log_stream_name": "${stream}-bootstrap",
            "timestamp_format": "%b %d %H:%M:%S"
          },
          {
            "file_path": "/var/log/${GAME_NAME}/server.log",
            "log_group_name": "${server_group}",
            "log_stream_name": "${stream}-server",
            "timestamp_format": "%b %d %H:%M:%S"
          },
          {
            "file_path": "/var/log/${GAME_NAME}/server.error.log",
            "log_group_name": "${server_group}",
            "log_stream_name": "${stream}-server-error",
            "timestamp_format": "%b %d %H:%M:%S"
          }
        ]
      }
    }
  }
}
EOF
  /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
    -a fetch-config -m ec2 -s \
    -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json || true
}

upload_state() {
  aws s3 sync "${STATE_DIR_PATH}/" "s3://${WORLD_BUCKET}/${WORLD_PREFIX}/state/" --delete || true
}

install_game() {
  mkdir -p /opt/steamcmd "${GAME_HOME%/*}"
  if [[ ! -x /opt/steamcmd/steamcmd.sh ]]; then
    curl -fsSL https://steamcdn-a.akamaihd.net/client/installer/steamcmd_linux.tar.gz -o /tmp/steamcmd_linux.tar.gz
    tar -xzf /tmp/steamcmd_linux.tar.gz -C /opt/steamcmd
    chmod +x /opt/steamcmd/steamcmd.sh
  fi

  ensure_steamcmd_runtime() {
    if /opt/steamcmd/linux32/steamcmd +quit >/dev/null 2>&1; then
      return 0
    fi

    echo "SteamCMD runtime check failed; attempting to install 32-bit compatibility dependencies."
    if command -v dnf >/dev/null 2>&1; then
      dnf -y install glibc.i686 libgcc.i686 libstdc++.i686 || true
      dnf -y install glibc-devel.i686 libstdc++-devel.i686 || true
    elif command -v yum >/dev/null 2>&1; then
      yum -y install glibc.i686 libgcc.i686 libstdc++.i686 || true
    elif command -v apt-get >/dev/null 2>&1; then
      dpkg --add-architecture i386 || true
      apt-get update || true
      apt-get install -y libc6-i386 libstdc++6:i386 libgcc-s1:i386 || true
      apt-get install -y libc6:i386 libstdc++6:i386 libgcc1:i386 || true
      apt-get install -y libc6:i386 libstdc++6:i386 lib32gcc-s1 || true
      apt-get install -y lib32stdc++6 || true
      apt-get install -y lib32gcc1 || true
    fi

    if /opt/steamcmd/linux32/steamcmd +quit >/dev/null 2>&1; then
      return 0
    fi
    return 1
  }

  ensure_steamcmd_runtime || true

  install_cmd="$(decode "${GAME_INSTALL_CMD_B64}")"
  install_branches=( )
  if [[ -n "${STEAM_BETA_BRANCH}" ]]; then
    install_branches+=("${STEAM_BETA_BRANCH}")
  fi
  install_branches+=("")
  if [[ "${STEAM_BETA_BRANCH}" == "latest_experimental" ]]; then
    install_branches+=("experimental")
  fi

  for branch in "${install_branches[@]}"; do
    if [[ -n "${branch}" ]]; then
      STEAM_BETA_BRANCH="${branch}"
    else
      STEAM_BETA_BRANCH=""
    fi
    if STEAM_BETA_BRANCH="${STEAM_BETA_BRANCH}" STEAM_BETA_PASSWORD="${STEAM_BETA_PASSWORD}" bash -lc "${install_cmd}"; then
      return 0
    fi
  done
  return 1
}

cat > "/opt/${GAME_SERVICE}-tools/restore-state.sh" <<'EOS'
#!/usr/bin/env bash
set -euo pipefail
WORLD_BUCKET='{{WORLD_BUCKET}}'
WORLD_PREFIX='{{WORLD_PREFIX}}'
STATE_DIR_PATH='{{STATE_DIR_PATH}}'
[[ -n "${WORLD_BUCKET}" ]] && [[ -n "${WORLD_PREFIX}" ]] && aws s3 sync "s3://${WORLD_BUCKET}/${WORLD_PREFIX}/state/" "${STATE_DIR_PATH}/" || true
EOS

cat > "/opt/${GAME_SERVICE}-tools/upload-state.sh" <<'EOS'
#!/usr/bin/env bash
set -euo pipefail
WORLD_BUCKET='{{WORLD_BUCKET}}'
WORLD_PREFIX='{{WORLD_PREFIX}}'
STATE_DIR_PATH='{{STATE_DIR_PATH}}'
GAMECONFIG_LOCAL_PATH='{{GAMECONFIG_LOCAL_PATH}}'
if [[ -n "${WORLD_BUCKET}" ]] && [[ -n "${WORLD_PREFIX}" ]]; then
  aws s3 sync "${STATE_DIR_PATH}/" "s3://${WORLD_BUCKET}/${WORLD_PREFIX}/state/" --delete || true
fi
if [[ -n "${GAMECONFIG_LOCAL_PATH}" ]] && [[ -f "${GAMECONFIG_LOCAL_PATH}" ]]; then
  aws s3 cp "${GAMECONFIG_LOCAL_PATH}" "s3://${WORLD_BUCKET}/${GAMECONFIG_S3_KEY}" || true
fi
EOS

cat > "/opt/${GAME_SERVICE}-tools/stop-server.command" <<'EOS'
#!/usr/bin/env bash
set -euo pipefail
STOP_TIMEOUT_SECONDS='{{STOP_TIMEOUT_SECONDS}}'
game_pids="$(pgrep -f "7DaysToDieServer.x86_64" || true)"
if [[ -n "${game_pids}" ]]; then
  while IFS= read -r game_pid; do
    kill -s TERM "${game_pid}" 2>/dev/null || true
  done <<< "${game_pids}"
  sleep "${STOP_TIMEOUT_SECONDS}"
fi
remaining="$(pgrep -f "7DaysToDieServer.x86_64" || true)"
if [[ -n "${remaining}" ]]; then
  while IFS= read -r game_pid; do
    kill -s KILL "${game_pid}" 2>/dev/null || true
  done <<< "${remaining}"
fi
"/opt/{{GAME_SERVICE}}-tools/upload-state.sh" || true
EOS

cat > "/opt/${GAME_SERVICE}-tools/start-server.command" <<'EOS'
#!/usr/bin/env bash
set -euo pipefail
GAME_NAME='{{GAME_NAME}}'
GAME_HOME='{{GAME_HOME}}'
GAMECONFIG_LOCAL_PATH='{{GAMECONFIG_LOCAL_PATH}}'
GAMECONFIG_S3_KEY='{{GAMECONFIG_S3_KEY}}'
WORLD_BUCKET='{{WORLD_BUCKET}}'
WORLD_PREFIX='{{WORLD_PREFIX}}'
GAME_START_CMD_B64='{{GAME_START_CMD_B64}}'

ensure_steamclient() {
  local steam_lib="/opt/steamcmd/linux64/steamclient.so"
  if [[ ! -f "${steam_lib}" ]]; then
    steam_lib="/opt/steamcmd/linux32/steamclient.so"
  fi
  if [[ ! -f "${steam_lib}" ]]; then
    return 0
  fi

  local runtime_user="${USER:-$(whoami)}"
  local user_home="${HOME:-}"
  if [[ -z "${user_home}" || ! -d "${user_home}" ]]; then
    user_home="$(getent passwd "${runtime_user}" | cut -d: -f6 || true)"
  fi
  if [[ -n "${user_home}" ]]; then
    mkdir -p "${user_home}/.steam/sdk64"
    ln -sf "${steam_lib}" "${user_home}/.steam/sdk64/steamclient.so"
  fi
}

runtime_user="${USER:-$(whoami)}"
export USER="${runtime_user}"
export HOME="${HOME:-$(getent passwd "${runtime_user}" | cut -d: -f6 || true)}"

mkdir -p "$(dirname "${GAMECONFIG_LOCAL_PATH}")"
if [[ -n "${WORLD_BUCKET}" && -n "${GAMECONFIG_S3_KEY}" ]]; then
  aws s3 cp "s3://${WORLD_BUCKET}/${GAMECONFIG_S3_KEY}" "${GAMECONFIG_LOCAL_PATH}" || true
fi
if [[ ! -f "${GAMECONFIG_LOCAL_PATH}" ]]; then
  cat <<XML > "${GAMECONFIG_LOCAL_PATH}"
<ServerSettings>
  <property name="BloodMoonFrequency" value="7" />
  <property name="BloodMoonRange" value="2" />
  <property name="DropOnDeath" value="2" />
  <property name="PlayerKillingMode" value="2" />
  <property name="AirDropMarker" value="true" />
</ServerSettings>
XML
fi
mkdir -p "${GAME_HOME}"
mkdir -p "${STATE_LINK%/*}" || true
mkdir -p "/home/$(whoami)/.local/share/7DaysToDie" || true
ensure_steamclient
eval "$(printf '%s' "${GAME_START_CMD_B64}" | base64 -d)"
EOS

cat > "/opt/${GAME_SERVICE}-tools/spot-watchdog.sh" <<'EOS'
#!/usr/bin/env bash
set -euo pipefail
NOTICE_URL="http://169.254.169.254/latest/meta-data/spot/instance-action"
while true; do
  if notice="$(curl -fsS --max-time 1 "${NOTICE_URL}" || true)"; then
    if [[ "${notice}" == *\"action\"* ]]; then
      "/opt/{{GAME_SERVICE}}-tools/upload-state.sh" || true
      /usr/bin/systemctl stop "{{GAME_SERVICE}}-server.service" || true
      /usr/sbin/shutdown -h now "Spot termination notice"
      exit 0
    fi
  fi
  sleep 15
done
EOS

chmod +x "/opt/${GAME_SERVICE}-tools/restore-state.sh" \
  "/opt/${GAME_SERVICE}-tools/upload-state.sh" \
  "/opt/${GAME_SERVICE}-tools/spot-watchdog.sh" \
  "/opt/${GAME_SERVICE}-tools/stop-server.command" \
  "/opt/${GAME_SERVICE}-tools/start-server.command"

cat > "/etc/systemd/system/${GAME_SERVICE}-server.service" <<SERVER_SERVICE
[Unit]
Description=${GAME_NAME} dedicated server
After=network.target

[Service]
Type=simple
User=${SERVICE_USER}
WorkingDirectory=${GAME_HOME}
Environment=STATE_DIR_PATH=${STATE_DIR_PATH}
Environment=WORLD_BUCKET={{WORLD_BUCKET}}
Environment=WORLD_PREFIX=${WORLD_PREFIX}
Environment=GAME_HOME=${GAME_HOME}
Environment=GAMECONFIG_S3_KEY=${GAMECONFIG_S3_KEY}
Environment=GAMECONFIG_LOCAL_PATH=${GAMECONFIG_LOCAL_PATH}
Environment=GAME_SERVICE=${GAME_SERVICE}
Environment=STATE_LINK=${STATE_LINK}
Environment=BACKUP_INTERVAL_MINUTES={{BACKUP_INTERVAL_MINUTES}}
Environment=BACKUP_BOOT_OFFSET_MINUTES={{BACKUP_BOOT_OFFSET_MINUTES}}
Environment=STOP_TIMEOUT_SECONDS={{STOP_TIMEOUT_SECONDS}}
ExecStart=/opt/${GAME_SERVICE}-tools/start-server.command
ExecStop=/opt/${GAME_SERVICE}-tools/stop-server.command
ExecStopPost=/opt/${GAME_SERVICE}-tools/upload-state.sh
Restart=always
RestartSec=5
TimeoutStopSec=120
KillMode=control-group
LimitNOFILE=10240
StandardOutput=append:/var/log/${GAME_NAME}/server.log
StandardError=append:/var/log/${GAME_NAME}/server.error.log

[Install]
WantedBy=multi-user.target
SERVER_SERVICE

cat > "/etc/systemd/system/${GAME_SERVICE}-watchdog.service" <<WATCHDOG_SERVICE
[Unit]
Description=Spot interruption watcher for ${GAME_NAME}
After=network.target

[Service]
Type=simple
ExecStart=/opt/${GAME_SERVICE}-tools/spot-watchdog.sh
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
WATCHDOG_SERVICE

cat > "/etc/systemd/system/${GAME_SERVICE}-backup.service" <<BACKUP_SERVICE
[Unit]
Description=${GAME_NAME} periodic backup

[Service]
Type=oneshot
ExecStart=/opt/${GAME_SERVICE}-tools/upload-state.sh
BACKUP_SERVICE

cat > "/etc/systemd/system/${GAME_SERVICE}-backup.timer" <<BACKUP_TIMER
[Unit]
Description=${GAME_NAME} state backup timer

[Timer]
OnBootSec={{BACKUP_BOOT_OFFSET_MINUTES}}min
OnUnitActiveSec={{BACKUP_INTERVAL_MINUTES}}min
Persistent=true

[Install]
WantedBy=timers.target
BACKUP_TIMER

systemctl daemon-reload
configure_cloudwatch_agent
restore_state
install_game

if [[ -n "${GAMECONFIG_S3_KEY}" ]]; then
  GAMECONFIG_LOCAL_PATH="${GAMECONFIG_LOCAL_PATH}" WORLD_BUCKET="{{WORLD_BUCKET}}" WORLD_PREFIX="{{WORLD_PREFIX}}" /opt/${GAME_SERVICE}-tools/start-server.command || true
fi

if id -u "${SERVICE_USER}" >/dev/null 2>&1; then
  chown -R "${SERVICE_USER}:${SERVICE_USER}" \
    "${GAME_HOME}" \
    "${STATE_DIR_PATH}" \
    "${STATE_LINK%/*}" \
    "/var/log/${GAME_NAME}" || true
  chmod -R u+rwX "${STATE_DIR_PATH}" "/var/log/${GAME_NAME}" || true
fi

cat > /etc/sysctl.d/99-${GAME_SERVICE}.conf <<SYSCTL
vm.max_map_count=262144
SYSCTL
sysctl -p /etc/sysctl.d/99-${GAME_SERVICE}.conf || true

systemctl enable "${GAME_SERVICE}-server.service" "${GAME_SERVICE}-watchdog.service" "${GAME_SERVICE}-backup.timer"
systemctl start "${GAME_SERVICE}-server.service"
systemctl start "${GAME_SERVICE}-backup.timer"

cat <<INFO
{{GAME_NAME}} bootstrap complete.
Game files: ${GAME_HOME}
State path: ${STATE_DIR_PATH}
World path: ${WORLD_PREFIX}
INFO
