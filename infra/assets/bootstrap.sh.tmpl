cat > "/opt/${GAME_SERVICE}-tools/idle-shutdown.sh" <<'EOS'
#!/usr/bin/env bash
set -euo pipefail
GAME_SERVICE='{{GAME_SERVICE}}'
IDLE_LIMIT_SECONDS=1200
LOG_FILE="/var/log/${GAME_SERVICE}/server.log"
STATE_DIR="/var/lib/${GAME_SERVICE}"
STATE_FILE="${STATE_DIR}/zero-player-since"

mkdir -p "${STATE_DIR}"

if ! systemctl is-active --quiet "${GAME_SERVICE}-server.service"; then
  rm -f "${STATE_FILE}"
  exit 0
fi

if [[ ! -f "${LOG_FILE}" ]] || ! grep -q "StartGame done" "${LOG_FILE}"; then
  exit 0
fi

latest_ply="$(
  tac "${LOG_FILE}" | grep -m1 -oE 'Ply: [0-9]+' | awk '{print $2}' || true
)"

if [[ -z "${latest_ply}" ]]; then
  exit 0
fi

now="$(date +%s)"
if [[ "${latest_ply}" != "0" ]]; then
  rm -f "${STATE_FILE}"
  exit 0
fi

if [[ ! -f "${STATE_FILE}" ]]; then
  printf '%s\n' "${now}" > "${STATE_FILE}"
  exit 0
fi

zero_since="$(cat "${STATE_FILE}" 2>/dev/null || echo "${now}")"
if (( now - zero_since >= IDLE_LIMIT_SECONDS )); then
  echo "No players for at least ${IDLE_LIMIT_SECONDS}s; backing up and terminating instance."
  "/opt/{{GAME_SERVICE}}-tools/upload-state.sh" || true
  systemctl stop "${GAME_SERVICE}-server.service" || true
  instance_id="$(curl -fsS http://169.254.169.254/latest/meta-data/instance-id)"
  region="$(curl -fsS http://169.254.169.254/latest/dynamic/instance-identity/document | sed -n 's/.*"region"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
  aws ec2 terminate-instances --region "${region}" --instance-ids "${instance_id}" || shutdown -h now
fi
EOS

cat > "/opt/${GAME_SERVICE}-tools/stop-server.command" <<'EOS'
#!/usr/bin/env bash
set -euo pipefail
STOP_TIMEOUT_SECONDS='{{STOP_TIMEOUT_SECONDS}}'
GAME_SERVICE='{{GAME_SERVICE}}'
if [[ "${GAME_SERVICE}" == "windrose" ]] && command -v docker >/dev/null 2>&1; then
  docker stop --time "${STOP_TIMEOUT_SECONDS}" WindroseServer >/dev/null 2>&1 || true
  "/opt/{{GAME_SERVICE}}-tools/upload-state.sh" || true
  exit 0
fi
game_pids="$(pgrep -f "7DaysToDieServer.x86_64" || true)"
if [[ -n "${game_pids}" ]]; then
  while IFS= read -r game_pid; do
    kill -s TERM "${game_pid}" 2>/dev/null || true
  done <<< "${game_pids}"
  sleep "${STOP_TIMEOUT_SECONDS}"
fi
remaining="$(pgrep -f "7DaysToDieServer.x86_64" || true)"
if [[ -n "${remaining}" ]]; then
  while IFS= read -r game_pid; do
    kill -s KILL "${game_pid}" 2>/dev/null || true
  done <<< "${remaining}"
fi
"/opt/{{GAME_SERVICE}}-tools/upload-state.sh" || true
EOS

